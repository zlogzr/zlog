---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}
interface Props {
  headings: Heading[];
}
const { headings } = Astro.props;
// 只取 ## 和 ### 两级
const toc = headings.filter((h) => h.depth === 2 || h.depth === 3);
---
{toc.length >= 2 && (
  <nav class="toc" aria-label="文章目录">
    <p class="toc-title">目录</p>
    <ul>
      {toc.map((h) => (
        <li class={`lvl-${h.depth}`}>
          <a href={`#${h.slug}`} data-toc={h.slug}>{h.text}</a>
        </li>
      ))}
    </ul>
  </nav>
)}

<style>
  .toc {
    display: none; /* 默认隐藏，宽屏才显示 */
  }
  /* 视口够宽时，把目录固定在正文右侧空白处 */
  @media (min-width: 1200px) {
    .toc {
      display: block;
      position: fixed;
      top: 96px;
      left: calc(50% + 384px);
      width: 200px;
      max-height: 72vh;
      overflow-y: auto;
      font-size: 0.85rem;
      line-height: 1.5;
    }
    .toc-title {
      margin: 0 0 8px;
      font-weight: 600;
      color: var(--text);
    }
    .toc ul {
      list-style: none;
      margin: 0;
      padding: 0;
      border-left: 1px solid var(--border);
    }
    .toc li {
      margin: 0;
    }
    .toc li.lvl-3 a {
      padding-left: 28px;
      font-size: 0.8rem;
    }
    .toc a {
      display: block;
      padding: 4px 0 4px 14px;
      margin-left: -1px;
      border-left: 2px solid transparent;
      color: var(--text-soft);
      text-decoration: none;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .toc a:hover {
      color: var(--text);
    }
    .toc a.active {
      color: var(--accent);
      border-left-color: var(--accent);
    }
  }
</style>

<script>
  const links = document.querySelectorAll<HTMLAnchorElement>('.toc a[data-toc]');
  if (links.length) {
    const map = new Map<string, HTMLAnchorElement>();
    links.forEach((l) => map.set(l.dataset.toc!, l));

    const headings = document.querySelectorAll('article :is(h2, h3)[id]');
    let activeId = '';
    const setActive = (id: string) => {
      if (id === activeId) return;
      activeId = id;
      links.forEach((l) => l.classList.remove('active'));
      map.get(id)?.classList.add('active');
    };

    const observer = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (e.isIntersecting) setActive((e.target as HTMLElement).id);
        }
      },
      { rootMargin: '-80px 0px -70% 0px', threshold: 0 },
    );
    headings.forEach((h) => observer.observe(h));
  }
</script>
